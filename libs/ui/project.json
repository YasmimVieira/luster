{
  "name": "ui",
  "sourceRoot": "libs/ui/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "options": {
        "project": "libs/ui/ng-package.json"
      }
    },
"storybook": {
  "executor": "@storybook/angular:start-storybook",
  "options": {
    "port": 4400,
    "configDir": "libs/ui/.storybook", 
    "browserTarget": "ui:build-storybook-context",
    "compodoc": false
  }
},
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "options": {
        "outputDir": "dist/storybook/ui",
        "configDir": "libs/ui/.storybook",
        "browserTarget": "ui:build-storybook-context",
        "compodoc": false
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c libs/ui/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": [
        "build-storybook"
      ],
      "options": {
        "buildTarget": "ui:build-storybook",
        "staticFilePath": "dist/storybook/ui",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "ui:build-storybook:ci"
        }
      }
    },
    "build-storybook-context": {
      "executor": "@angular-devkit/build-angular:browser",
      "options": {
        "outputPath": "dist/libs/ui/.storybook",
        "index": "libs/ui/src/index.html",
        "main": "libs/ui/src/test.ts",
        "tsConfig": "libs/ui/.storybook/tsconfig.storybook.json",
        "assets": [],
        "styles": [],
        "scripts": []
      }
    }
  }
}